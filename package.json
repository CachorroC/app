{
  "name": "app",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "styles:tcm": "tcm src",
    "sass": "sass --no-source-map src:src && tcm src",
    "lint": "next lint --fix --strict && next lint --strict",
    "devbuild": "sass --no-source-map src:src && tcm src && pnpm memoriales:generate-registry && eslint --fix . && next build",
    "build": "sass --no-source-map src:src && tcm src && pnpm memoriales:generate-registry && next build",
    "dev": "concurrently -n web,render -c blue,magenta \"pnpm dev:web\" \"pnpm dev:render\"",
    "dev:web": "sass --no-source-map src:src && tcm src && pnpm memoriales:generate-registry && URL=beta.rsasesorjuridico.com NEXTAUTH_URL=https://beta.rsasesorjuridico.com next dev",
    "dev:render": "cd services/memoriales-render && .venv/bin/uvicorn render_service:app --host 127.0.0.1 --port 8787 --reload",
    "start": "next start",
    "memoriales:generate-registry": "tsx src/memoriales/tooling/generate-registry.ts",
    "test:memoriales-parity": "tsx --test src/memoriales/tooling/memoriales-parity.test.ts",
    "test:memoriales": "tsx --test src/memoriales/lib/*.test.ts src/memoriales/tooling/*.test.ts",
    "db:migrate": "prisma migrate dev --name init --create-only && prisma generate",
    "db:push": "prisma db push",
    "json-to-prisma": "json-to-prisma-schema-convertor convert --inputPath='./prisma/schema.json' --outputPath='./prisma/new/schema.prisma'",
    "db:test": "tsx scripts/test-database.ts",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate && ts-node src/lib/scripts/generate-dmmf.ts",
    "postinstall": "node scripts/enforce-strict-css.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-data-grid": "^9.10.0",
    "@mui/x-data-grid-premium": "^9.10.0",
    "@mui/x-data-grid-pro": "^9.10.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@yudiel/react-qr-scanner": "latest",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "fflate": "^0.8.3",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "material-symbols": "^0.45.8",
    "mongodb": "^7.5.0",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.7",
    "react-currency-input-field": "^4.0.6",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.82.0",
    "sass": "^1.101.0",
    "server-only": "^0.0.1",
    "tsx": "^4.23.1",
    "typed-css-modules": "^0.9.1",
    "typed-scss-modules": "^8.1.1",
    "typescript-eslint": "^8.64.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.4.3",
    "@prisma/internals": "^7.8.0",
    "@types/web-push": "^3.6.4",
    "concurrently": "^10.0.3",
    "ts-node": "^10.9.2",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.9.3"
  }
}
