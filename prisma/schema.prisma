generator client {
  provider     = "prisma-client"
  output       = "../src/app/generated/prisma"
  engineType   = "client"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Carpeta {
  id                  Int
  fecha               DateTime?
  idProcesos          String[]
  llaveProceso        String
  nombre              String
  numero              Int        @id
  revisado            Boolean    @default(false)
  terminado           Boolean    @default(false)
  updatedAt           DateTime   @updatedAt
  tipoProceso         String     @default("SINGULAR")
  notasCount          Int?
  fechaUltimaRevision DateTime?
  ciudad              String?
  juzgadoTipo         String?
  juzgadoCiudad       String?
  juzgadoId           String?
  idRegUltimaAct      String?
  category            Category   @default(SinEspecificar)
  ultimaActuacion     Actuacion? @relation(fields: [idRegUltimaAct], references: [idRegActuacion])
  juzgado             Juzgado?   @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
  codeudor            Codeudor?
  demanda             Demanda?
  deudor              Deudor?
  notas               Nota[]
  procesos            Proceso[]
  notes               Note[]
  tareas              Tarea[]
}

model Deudor {
  carpetaNumero   Int     @unique
  cedula          String
  direccion       String?
  email           String?
  id              Int     @id
  primerApellido  String
  primerNombre    String
  segundoApellido String?
  segundoNombre   String?
  telCelular      String?
  telFijo         String?
  carpeta         Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Codeudor {
  carpetaNumero Int     @unique
  cedula        String?
  direccion     String?
  id            Int     @id
  nombre        String?
  telefono      String?
  carpeta       Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Demanda {
  carpetaNumero           Int        @unique
  departamento            String?
  despacho                String?
  entregaGarantiasAbogado DateTime?
  etapaProcesal           String?
  llaveProceso            String?
  fechaPresentacion       DateTime[]
  id                      Int        @id
  tipoProceso             String
  municipio               String?
  obligacion              String[]
  radicado                String?
  vencimientoPagare       DateTime[]
  capitalAdeudado         Decimal    @default(0) @db.Money
  mandamientoPago         DateTime[]
  avaluo                  Decimal    @default(0) @db.Money
  liquidacion             Decimal    @default(0) @db.Money
  carpeta                 Carpeta    @relation(fields: [carpetaNumero], references: [numero])
}

model Nota {
  carpetaNumero Int?
  createdAt     DateTime        @default(now())
  id            String          @id
  pathname      String?
  updatedAt     DateTime        @updatedAt
  dueDate       DateTime?
  text          String
  content       String[]
  completed     Boolean         @default(false)
  carpeta       Carpeta?        @relation(fields: [carpetaNumero], references: [numero])
  relevantDates RelevantDates[]
}

model RelevantDates {
  date   DateTime
  text   String
  id     String   @id
  notaId String?
  nota   Nota?    @relation(fields: [notaId], references: [id])
}

model Actuacion {
  actuacion      String
  anotacion      String?
  cant           Int
  carpetaNumero  Int?
  codRegla       String
  conDocumentos  Boolean
  consActuacion  Int
  createdAt      DateTime  @default(now())
  fechaActuacion DateTime
  fechaFinal     DateTime?
  fechaInicial   DateTime?
  fechaRegistro  DateTime
  isUltimaAct    Boolean
  llaveProceso   String
  procesoId      String
  idProceso      String
  idRegActuacion String    @id
  proceso        Proceso   @relation(fields: [procesoId], references: [idProceso])
  carpetas       Carpeta[]
}

model Juzgado {
  id      String
  tipo    String
  ciudad  String
  url     String
  Carpeta Carpeta[]
  Proceso Proceso[]

  @@id([id, tipo, ciudad])
}

model Proceso {
  cantFilas            Int
  carpetaNumero        Int
  departamento         String
  despacho             String
  esPrivado            Boolean
  fechaProceso         DateTime?
  fechaUltimaActuacion DateTime?
  idConexion           Int
  idProceso            String      @id @unique
  juzgadoTipo          String
  llaveProceso         String
  sujetosProcesales    String
  juzgadoId            String
  juzgadoCiudad        String
  actuaciones          Actuacion[]
  carpeta              Carpeta     @relation(fields: [carpetaNumero], references: [numero])
  juzgado              Juzgado     @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
}

model Note {
  id          String           @id @default(cuid())
  titulo      String           @db.VarChar(200)
  resumen     String?          @db.VarChar(400)
  estado      EstadoNote       @default(PENDIENTE)
  fijada      Boolean          @default(false)
  carpetaId   Int?
  creadaEn    DateTime         @default(now())
  editadaEn   DateTime         @updatedAt
  archivadaEn DateTime?
  creadoPorId String?
  userId      String?
  etiquetas   EtiquetaEnNote[]
  bloques     NoteBloque[]
  carpeta     Carpeta?         @relation(fields: [carpetaId], references: [numero])
  creadoPor   User?            @relation("NotesCreadasPorUsuario", fields: [creadoPorId], references: [id])
  user        User?            @relation(fields: [userId], references: [id])
  tareas      Tarea[]          @relation("TareasOriginadasEnNote")
  asignados   UsuarioEnNote[]

  @@index([creadoPorId, editadaEn(sort: Desc)])
  @@index([carpetaId, editadaEn(sort: Desc)])
  @@index([estado, editadaEn(sort: Desc)])
  @@map("notes")
}

model NoteBloque {
  id     String       @id @default(cuid())
  noteId String
  tipo   TipoBloque
  orden  Int
  texto  String?
  items  BloqueItem[]
  note   Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, orden])
  @@map("note_bloques")
}

model BloqueItem {
  id           String     @id @default(cuid())
  bloqueId     String
  orden        Int
  texto        String
  completado   Boolean    @default(false)
  completadoEn DateTime?
  tareaId      String?    @unique
  bloque       NoteBloque @relation(fields: [bloqueId], references: [id], onDelete: Cascade)
  tarea        Tarea?     @relation("TareaPromovida", fields: [tareaId], references: [id])

  @@unique([bloqueId, orden])
  @@map("bloque_items")
}

model Tarea {
  id           String            @id @default(cuid())
  titulo       String            @db.VarChar(200)
  descripcion  String?
  estado       EstadoTarea       @default(PENDIENTE)
  prioridad    PrioridadTarea    @default(MEDIA)
  fechaLimite  DateTime?
  esTermino    Boolean           @default(false)
  responsable  String?           @db.VarChar(120)
  carpetaId    Int?
  noteOrigenId String?
  creadaEn     DateTime          @default(now())
  editadaEn    DateTime          @updatedAt
  completadaEn DateTime?
  archivadaEn  DateTime?
  creadoPorId  String?
  userId       String?
  itemOrigen   BloqueItem?       @relation("TareaPromovida")
  etiquetas    EtiquetaEnTarea[]
  carpeta      Carpeta?          @relation(fields: [carpetaId], references: [numero])
  creadoPor    User?             @relation("TareasCreadasPorUsuario", fields: [creadoPorId], references: [id])
  noteOrigen   Note?             @relation("TareasOriginadasEnNote", fields: [noteOrigenId], references: [id])
  user         User?             @relation(fields: [userId], references: [id])
  asignados    UsuarioEnTarea[]

  @@index([carpetaId, fechaLimite])
  @@index([estado, fechaLimite])
  @@index([fechaLimite, esTermino])
  @@map("tareas")
}

model Etiqueta {
  id     String            @id @default(cuid())
  nombre String            @unique @db.VarChar(60)
  color  String            @db.VarChar(9)
  notes  EtiquetaEnNote[]
  tareas EtiquetaEnTarea[]

  @@map("etiquetas")
}

model EtiquetaEnNote {
  noteId     String
  etiquetaId String
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([noteId, etiquetaId])
  @@map("etiquetas_en_notes")
}

model EtiquetaEnTarea {
  tareaId    String
  etiquetaId String
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  tarea      Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@id([tareaId, etiquetaId])
  @@map("etiquetas_en_tareas")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique @db.VarChar(180)
  nombre             String              @db.VarChar(120)
  rol                RolUsuario          @default(ABOGADO)
  activo             Boolean             @default(true)
  passwordHash       String?             @db.VarChar(100)
  tarjetaProfesional String?             @unique @db.VarChar(40)
  telefono           String?             @db.VarChar(40)
  avatarUrl          String?             @db.VarChar(500)
  creadoEn           DateTime            @default(now())
  editadoEn          DateTime            @updatedAt
  ultimoAccesoA      DateTime?
  desactivadoEn      DateTime?
  emailVerificadoEn  DateTime?
  notesCreadas       Note[]              @relation("NotesCreadasPorUsuario")
  notes              Note[]
  sessions           Session[]
  tareasCreadas      Tarea[]             @relation("TareasCreadasPorUsuario")
  tareas             Tarea[]
  notesAsignadas     UsuarioEnNote[]
  tareasAsignadas    UsuarioEnTarea[]
  verificationTokens VerificationToken[]

  @@index([activo, nombre])
  @@map("users")
}

model UsuarioEnNote {
  userId        String
  noteId        String
  rol           RolAsignacion @default(COLABORADOR)
  asignadoEn    DateTime      @default(now())
  asignadoPorId String?
  note          Note          @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
  @@map("usuarios_en_notes")
}

model UsuarioEnTarea {
  userId        String
  tareaId       String
  rol           RolAsignacion @default(COLABORADOR)
  asignadoEn    DateTime      @default(now())
  asignadoPorId String?
  tarea         Tarea         @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, tareaId])
  @@index([tareaId])
  @@map("usuarios_en_tareas")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique @db.VarChar(64)
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.VarChar(64)
  tipo      TipoToken
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tipo])
  @@map("verification_tokens")
}

enum Category {
  Terminados
  LiosJuridicos
  Bancolombia
  Reintegra
  Insolvencia
  SinEspecificar
  todos
  SinTercero
}

enum Departamento {
  BOGOTA
  CUNDINAMARCA
  META
  ANTIOQUIA
  ATLANTICO
}

enum TipoProceso {
  HIPOTECARIO
  PRENDARIO
  SINGULAR
  ACUMULADO
}

enum RolUsuario {
  ADMIN
  ABOGADO
  ASISTENTE
  LECTOR
}

enum RolAsignacion {
  RESPONSABLE
  COLABORADOR
  OBSERVADOR
}

enum EstadoNote {
  PENDIENTE
  EN_REVISION
  ATENDIDA
  ARCHIVADA
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  ATENDIDA
  ARCHIVADA
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum TipoBloque {
  PARRAFO
  LISTA
  VERIFICACION
}

enum TipoToken {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
