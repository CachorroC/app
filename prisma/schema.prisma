generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Carpeta {
  id                  Int
  fecha               DateTime?
  idProcesos          String[]
  llaveProceso        String
  nombre              String
  numero              Int        @id
  revisado            Boolean    @default(false)
  terminado           Boolean    @default(false)
  updatedAt           DateTime   @updatedAt
  tipoProceso         String     @default("SINGULAR")
  notasCount          Int?
  fechaUltimaRevision DateTime?
  ciudad              String?
  juzgadoTipo         String?
  juzgadoCiudad       String?
  juzgadoId           String?
  idRegUltimaAct      String?
  category            Category   @default(SinEspecificar)
  ultimaActuacion     Actuacion? @relation(fields: [idRegUltimaAct], references: [idRegActuacion])
  juzgado             Juzgado?   @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
  codeudor            Codeudor?
  demanda             Demanda?
  deudor              Deudor?
  facturas            Factura[]
  notas               Nota[]
  procesos            Proceso[]
  tareas              Task[]
}

model Factura {
  id                 String          @id
  facturaElectronica String?
  secondaryFactura   Json?
  ciudad             String
  dv                 Int
  fecha              DateTime
  razonSocial        String
  nombreComercial    String?
  direccion          String
  valorBase          Decimal         @db.Money
  hasOtroImp         Boolean         @default(false)
  hasIva             Boolean         @default(false)
  hasIcui            Boolean         @default(false)
  hasImpoConsumo     Boolean         @default(false)
  nit                Int
  valorIva           Decimal?        @db.Money
  valorOtroImp       Decimal?        @db.Money
  valorTotal         Decimal         @db.Money
  concepto           String
  carpetaNumero      Int?
  CUFE               String?
  QRCode             String?
  carpeta            Carpeta?        @relation(fields: [carpetaNumero], references: [numero])
  emisorDeFactura    EmisorDeFactura @relation(fields: [nit], references: [nit])
}

model EmisorDeFactura {
  nit                       Int       @id
  dv                        Int
  razonSocial               String
  nombreComercial           String?
  direccion                 String?
  correo                    String?
  telefono                  Int?
  actividadEconomica        String?
  regimenFiscal             String?
  responsabilidadTributaria String?
  tipoContribuyente         String    @default("Juridica")
  ciudad                    String    @default("Bogota")
  facturas                  Factura[]
}

model Deudor {
  carpetaNumero   Int     @unique
  cedula          String
  direccion       String?
  email           String?
  id              Int     @id
  primerApellido  String
  primerNombre    String
  segundoApellido String?
  segundoNombre   String?
  telCelular      String?
  telFijo         String?
  carpeta         Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Codeudor {
  carpetaNumero Int     @unique
  cedula        String?
  direccion     String?
  id            Int     @id
  nombre        String?
  telefono      String?
  carpeta       Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Demanda {
  carpetaNumero           Int                @unique
  departamento            String?
  despacho                String?
  entregaGarantiasAbogado DateTime?
  etapaProcesal           String?
  llaveProceso            String?
  fechaPresentacion       DateTime[]
  id                      Int                @id
  tipoProceso             String
  municipio               String?
  obligacion              String[]
  radicado                String?
  vencimientoPagare       DateTime[]
  capitalAdeudado         Decimal            @default(0) @db.Money
  mandamientoPago         DateTime[]
  avaluo                  Decimal            @default(0) @db.Money
  liquidacion             Decimal            @default(0) @db.Money
  carpeta                 Carpeta            @relation(fields: [carpetaNumero], references: [numero])
  medidasCautelares       MedidasCautelares?
  notificacion            Notificacion?
}

model Notificacion {
  demandaId      Int        @unique
  certimail      Boolean?
  fisico         Boolean?
  id             Int        @id
  autoNotificado DateTime?
  demanda        Demanda    @relation(fields: [demandaId], references: [id])
  notifiers      Notifier[]
}

model MedidasCautelares {
  demandaId         Int       @unique
  fechaOrdenaMedida DateTime?
  id                Int       @id
  medidaSolicitada  String?
  demanda           Demanda   @relation(fields: [demandaId], references: [id])
}

model Notifier {
  fechaAporta    DateTime?
  fechaRecibido  DateTime?
  notificacionId Int
  resultado      Boolean?
  tipo           String
  carpetaNumero  Int
  notificacion   Notificacion @relation(fields: [notificacionId], references: [id])

  @@id([tipo, carpetaNumero])
}

model Nota {
  carpetaNumero Int?
  createdAt     DateTime  @default(now())
  id            String    @id
  pathname      String?
  updatedAt     DateTime  @updatedAt
  dueDate       DateTime?
  text          String
  content       String[]
  carpeta       Carpeta?  @relation(fields: [carpetaNumero], references: [numero])
}

model Task {
  carpetaNumero Int?
  done          Boolean  @default(false)
  createdAt     DateTime @default(now())
  dueDate       DateTime
  id            Int      @id @default(autoincrement())
  text          String
  updatedAt     DateTime @updatedAt
  content       String[]
  carpeta       Carpeta? @relation(fields: [carpetaNumero], references: [numero])
}

model Actuacion {
  actuacion      String
  anotacion      String?
  cant           Int
  carpetaNumero  Int?
  codRegla       String
  conDocumentos  Boolean
  consActuacion  Int
  createdAt      DateTime  @default(now())
  fechaActuacion DateTime
  fechaFinal     DateTime?
  fechaInicial   DateTime?
  fechaRegistro  DateTime
  isUltimaAct    Boolean
  llaveProceso   String
  procesoId      String
  idProceso      String
  idRegActuacion String    @id
  proceso        Proceso   @relation(fields: [procesoId], references: [idProceso])
  Carpeta        Carpeta[]
}

model Juzgado {
  id      String
  tipo    String
  ciudad  String
  url     String
  Carpeta Carpeta[]
  Proceso Proceso[]

  @@id([id, tipo, ciudad])
}

model Proceso {
  cantFilas            Int
  carpetaNumero        Int
  departamento         String
  despacho             String
  esPrivado            Boolean
  fechaProceso         DateTime?
  fechaUltimaActuacion DateTime?
  idConexion           Int
  idProceso            String      @id @unique
  juzgadoTipo          String
  llaveProceso         String
  sujetosProcesales    String
  juzgadoId            String
  juzgadoCiudad        String
  actuaciones          Actuacion[]
  carpeta              Carpeta     @relation(fields: [carpetaNumero], references: [numero])
  juzgado              Juzgado     @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

enum NotifierName {
  DOS91
  DOS92
}

enum Category {
  Terminados
  LiosJuridicos
  Bancolombia
  Reintegra
  Insolvencia
  SinEspecificar
  todos
  SinTercero
}

enum Departamento {
  BOGOTA
  CUNDINAMARCA
  META
  ANTIOQUIA
  ATLANTICO
}

enum TipoProceso {
  HIPOTECARIO
  PRENDARIO
  SINGULAR
  ACUMULADO
}
