generator client {
  provider            = "prisma-client"
  output              = "../src/prisma/generated/prisma"
  engineType          = "client"
  importFileExtension = "js"
  moduleFormat        = "esm"
}

datasource db {
  provider = "postgresql"
}

model Carpeta {
  id                  Int
  fecha               DateTime?
  idProcesos          String[]
  llaveProceso        String
  nombre              String
  numero              Int        @id
  revisado            Boolean    @default(false)
  terminado           Boolean    @default(false)
  updatedAt           DateTime   @updatedAt
  tipoProceso         String     @default("SINGULAR")
  notasCount          Int?
  fechaUltimaRevision DateTime?
  ciudad              String?
  juzgadoTipo         String?
  juzgadoCiudad       String?
  juzgadoId           String?
  idRegUltimaAct      String?
  category            Category   @default(SinEspecificar)
  ultimaActuacion     Actuacion? @relation(fields: [idRegUltimaAct], references: [idRegActuacion])
  juzgado             Juzgado?   @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
  codeudor            Codeudor?
  demanda             Demanda?
  deudor              Deudor?
  notas               Nota[]
  procesos            Proceso[]
  notes               notes[]
  tareas              tareas[]
}

model Deudor {
  carpetaNumero   Int     @unique
  cedula          String
  direccion       String?
  email           String?
  id              Int     @id
  primerApellido  String
  primerNombre    String
  segundoApellido String?
  segundoNombre   String?
  telCelular      String?
  telFijo         String?
  carpeta         Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Codeudor {
  carpetaNumero Int     @unique
  cedula        String?
  direccion     String?
  id            Int     @id
  nombre        String?
  telefono      String?
  carpeta       Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Demanda {
  carpetaNumero           Int        @unique
  departamento            String?
  despacho                String?
  entregaGarantiasAbogado DateTime?
  etapaProcesal           String?
  llaveProceso            String?
  fechaPresentacion       DateTime[]
  id                      Int        @id
  tipoProceso             String
  municipio               String?
  obligacion              String[]
  radicado                String?
  vencimientoPagare       DateTime[]
  capitalAdeudado         Decimal    @default(0) @db.Money
  mandamientoPago         DateTime[]
  avaluo                  Decimal    @default(0) @db.Money
  liquidacion             Decimal    @default(0) @db.Money
  carpeta                 Carpeta    @relation(fields: [carpetaNumero], references: [numero])
}

model Nota {
  carpetaNumero Int?
  createdAt     DateTime        @default(now())
  id            String          @id
  pathname      String?
  updatedAt     DateTime        @updatedAt
  dueDate       DateTime?
  text          String
  content       String[]
  completed     Boolean         @default(false)
  carpeta       Carpeta?        @relation(fields: [carpetaNumero], references: [numero])
  RelevantDates RelevantDates[]
}

model Actuacion {
  actuacion      String
  anotacion      String?
  cant           Int
  carpetaNumero  Int?
  codRegla       String
  conDocumentos  Boolean
  consActuacion  Int
  createdAt      DateTime  @default(now())
  fechaActuacion DateTime
  fechaFinal     DateTime?
  fechaInicial   DateTime?
  fechaRegistro  DateTime
  isUltimaAct    Boolean
  llaveProceso   String
  procesoId      String
  idProceso      String
  idRegActuacion String    @id
  proceso        Proceso   @relation(fields: [procesoId], references: [idProceso])
  Carpeta        Carpeta[]
}

model Juzgado {
  id      String
  tipo    String
  ciudad  String
  url     String
  Carpeta Carpeta[]
  Proceso Proceso[]

  @@id([id, tipo, ciudad])
}

model Proceso {
  cantFilas            Int
  carpetaNumero        Int
  departamento         String
  despacho             String
  esPrivado            Boolean
  fechaProceso         DateTime?
  fechaUltimaActuacion DateTime?
  idConexion           Int
  idProceso            String      @id @unique
  juzgadoTipo          String
  llaveProceso         String
  sujetosProcesales    String
  juzgadoId            String
  juzgadoCiudad        String
  actuaciones          Actuacion[]
  carpeta              Carpeta     @relation(fields: [carpetaNumero], references: [numero])
  juzgado              Juzgado     @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
}

model RelevantDates {
  date   DateTime
  text   String
  id     String   @id
  notaId String?
  Nota   Nota?    @relation(fields: [notaId], references: [id])
}

model bloque_items {
  id           String       @id
  bloqueId     String
  orden        Int
  texto        String
  completado   Boolean      @default(false)
  completadoEn DateTime?
  tareaId      String?      @unique
  note_bloques note_bloques @relation(fields: [bloqueId], references: [id], onDelete: Cascade)
  tareas       tareas?      @relation(fields: [tareaId], references: [id])

  @@unique([bloqueId, orden])
}

model etiquetas {
  id                  String                @id
  nombre              String                @unique @db.VarChar(60)
  color               String                @db.VarChar(9)
  etiquetas_en_notes  etiquetas_en_notes[]
  etiquetas_en_tareas etiquetas_en_tareas[]
}

model etiquetas_en_notes {
  noteId     String
  etiquetaId String
  etiquetas  etiquetas @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  notes      notes     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([noteId, etiquetaId])
}

model etiquetas_en_tareas {
  tareaId    String
  etiquetaId String
  etiquetas  etiquetas @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  tareas     tareas    @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@id([tareaId, etiquetaId])
}

model note_bloques {
  id           String         @id
  noteId       String
  tipo         TipoBloque
  orden        Int
  texto        String?
  bloque_items bloque_items[]
  notes        notes          @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, orden])
}

model notes {
  id                             String               @id
  titulo                         String               @db.VarChar(200)
  resumen                        String?              @db.VarChar(400)
  estado                         EstadoNote           @default(PENDIENTE)
  fijada                         Boolean              @default(false)
  carpetaId                      Int?
  creadaEn                       DateTime             @default(now())
  editadaEn                      DateTime
  archivadaEn                    DateTime?
  creadoPorId                    String?
  userId                         String?
  etiquetas_en_notes             etiquetas_en_notes[]
  note_bloques                   note_bloques[]
  Carpeta                        Carpeta?             @relation(fields: [carpetaId], references: [numero])
  users_notes_creadoPorIdTousers users?               @relation("notes_creadoPorIdTousers", fields: [creadoPorId], references: [id])
  users_notes_userIdTousers      users?               @relation("notes_userIdTousers", fields: [userId], references: [id])
  tareas                         tareas[]
  usuarios_en_notes              usuarios_en_notes[]

  @@index([carpetaId, editadaEn(sort: Desc)])
  @@index([creadoPorId, editadaEn(sort: Desc)])
  @@index([estado, editadaEn(sort: Desc)])
}

model tareas {
  id                              String                @id
  titulo                          String                @db.VarChar(200)
  descripcion                     String?
  estado                          EstadoTarea           @default(PENDIENTE)
  prioridad                       PrioridadTarea        @default(MEDIA)
  fechaLimite                     DateTime?
  esTermino                       Boolean               @default(false)
  responsable                     String?               @db.VarChar(120)
  carpetaId                       Int?
  noteOrigenId                    String?
  creadaEn                        DateTime              @default(now())
  editadaEn                       DateTime
  completadaEn                    DateTime?
  archivadaEn                     DateTime?
  creadoPorId                     String?
  userId                          String?
  bloque_items                    bloque_items?
  etiquetas_en_tareas             etiquetas_en_tareas[]
  Carpeta                         Carpeta?              @relation(fields: [carpetaId], references: [numero])
  users_tareas_creadoPorIdTousers users?                @relation("tareas_creadoPorIdTousers", fields: [creadoPorId], references: [id])
  notes                           notes?                @relation(fields: [noteOrigenId], references: [id])
  users_tareas_userIdTousers      users?                @relation("tareas_userIdTousers", fields: [userId], references: [id])
  usuarios_en_tareas              usuarios_en_tareas[]

  @@index([carpetaId, fechaLimite])
  @@index([estado, fechaLimite])
  @@index([fechaLimite, esTermino])
}

model users {
  id                               String               @id
  email                            String               @unique @db.VarChar(180)
  nombre                           String               @db.VarChar(120)
  rol                              RolUsuario           @default(ABOGADO)
  activo                           Boolean              @default(true)
  passwordHash                     String?              @db.VarChar(100)
  tarjetaProfesional               String?              @unique @db.VarChar(40)
  telefono                         String?              @db.VarChar(40)
  avatarUrl                        String?              @db.VarChar(500)
  creadoEn                         DateTime             @default(now())
  editadoEn                        DateTime
  ultimoAccesoA                    DateTime?
  desactivadoEn                    DateTime?
  notes_notes_creadoPorIdTousers   notes[]              @relation("notes_creadoPorIdTousers")
  notes_notes_userIdTousers        notes[]              @relation("notes_userIdTousers")
  tareas_tareas_creadoPorIdTousers tareas[]             @relation("tareas_creadoPorIdTousers")
  tareas_tareas_userIdTousers      tareas[]             @relation("tareas_userIdTousers")
  usuarios_en_notes                usuarios_en_notes[]
  usuarios_en_tareas               usuarios_en_tareas[]

  @@index([activo, nombre])
}

model usuarios_en_notes {
  userId        String
  noteId        String
  rol           RolAsignacion @default(COLABORADOR)
  asignadoEn    DateTime      @default(now())
  asignadoPorId String?
  notes         notes         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  users         users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
}

model usuarios_en_tareas {
  userId        String
  tareaId       String
  rol           RolAsignacion @default(COLABORADOR)
  asignadoEn    DateTime      @default(now())
  asignadoPorId String?
  tareas        tareas        @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  users         users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, tareaId])
  @@index([tareaId])
}

enum Category {
  Terminados
  LiosJuridicos
  Bancolombia
  Reintegra
  Insolvencia
  SinEspecificar
  todos
  SinTercero
}

enum Departamento {
  BOGOTA
  CUNDINAMARCA
  META
  ANTIOQUIA
  ATLANTICO
}

enum TipoProceso {
  HIPOTECARIO
  PRENDARIO
  SINGULAR
  ACUMULADO
}

enum EstadoNote {
  PENDIENTE
  EN_REVISION
  ATENDIDA
  ARCHIVADA
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  ATENDIDA
  ARCHIVADA
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum RolAsignacion {
  RESPONSABLE
  COLABORADOR
  OBSERVADOR
}

enum RolUsuario {
  ADMIN
  ABOGADO
  ASISTENTE
  LECTOR
}

enum TipoBloque {
  PARRAFO
  LISTA
  VERIFICACION
}
