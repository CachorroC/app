generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Carpeta {
  id                  Int
  fecha               DateTime?
  idProcesos          String[]
  llaveProceso        String
  nombre              String
  numero              Int        @id
  revisado            Boolean    @default(false)
  terminado           Boolean    @default(false)
  updatedAt           DateTime   @updatedAt
  tipoProceso         String     @default("SINGULAR")
  notasCount          Int?
  fechaUltimaRevision DateTime?
  ciudad              String?
  juzgadoTipo         String?
  juzgadoCiudad       String?
  juzgadoId           String?
  idRegUltimaAct      String?
  category            Category   @default(SinEspecificar)
  ultimaActuacion     Actuacion? @relation(fields: [idRegUltimaAct], references: [idRegActuacion])
  juzgado             Juzgado?   @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
  codeudor            Codeudor?
  demanda             Demanda?
  deudor              Deudor?
  notas               Nota[]
  procesos            Proceso[]
}

model Deudor {
  carpetaNumero   Int     @unique
  cedula          String
  direccion       String?
  email           String?
  id              Int     @id
  primerApellido  String
  primerNombre    String
  segundoApellido String?
  segundoNombre   String?
  telCelular      String?
  telFijo         String?
  carpeta         Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Codeudor {
  carpetaNumero Int     @unique
  cedula        String?
  direccion     String?
  id            Int     @id
  nombre        String?
  telefono      String?
  carpeta       Carpeta @relation(fields: [carpetaNumero], references: [numero])
}

model Demanda {
  carpetaNumero           Int        @unique
  departamento            String?
  despacho                String?
  entregaGarantiasAbogado DateTime?
  etapaProcesal           String?
  llaveProceso            String?
  fechaPresentacion       DateTime[]
  id                      Int        @id
  tipoProceso             String
  municipio               String?
  obligacion              String[]
  radicado                String?
  vencimientoPagare       DateTime[]
  capitalAdeudado         Decimal    @default(0) @db.Money
  mandamientoPago         DateTime[]
  avaluo                  Decimal    @default(0) @db.Money
  liquidacion             Decimal    @default(0) @db.Money
  carpeta                 Carpeta    @relation(fields: [carpetaNumero], references: [numero])
}

model Nota {
  carpetaNumero Int?
  createdAt     DateTime        @default(now())
  id            String          @id
  pathname      String?
  updatedAt     DateTime        @updatedAt
  dueDate       DateTime?
  text          String
  content       String[]
  completed     Boolean         @default(false)
  carpeta       Carpeta?        @relation(fields: [carpetaNumero], references: [numero])
  RelevantDates RelevantDates[]
}

model Actuacion {
  actuacion      String
  anotacion      String?
  cant           Int
  carpetaNumero  Int?
  codRegla       String
  conDocumentos  Boolean
  consActuacion  Int
  createdAt      DateTime  @default(now())
  fechaActuacion DateTime
  fechaFinal     DateTime?
  fechaInicial   DateTime?
  fechaRegistro  DateTime
  isUltimaAct    Boolean
  llaveProceso   String
  procesoId      String
  idProceso      String
  idRegActuacion String    @id
  proceso        Proceso   @relation(fields: [procesoId], references: [idProceso])
  Carpeta        Carpeta[]
}

model Juzgado {
  id      String
  tipo    String
  ciudad  String
  url     String
  Carpeta Carpeta[]
  Proceso Proceso[]

  @@id([id, tipo, ciudad])
}

model Proceso {
  cantFilas            Int
  carpetaNumero        Int
  departamento         String
  despacho             String
  esPrivado            Boolean
  fechaProceso         DateTime?
  fechaUltimaActuacion DateTime?
  idConexion           Int
  idProceso            String      @id @unique
  juzgadoTipo          String
  llaveProceso         String
  sujetosProcesales    String
  juzgadoId            String
  juzgadoCiudad        String
  actuaciones          Actuacion[]
  carpeta              Carpeta     @relation(fields: [carpetaNumero], references: [numero])
  juzgado              Juzgado     @relation(fields: [juzgadoId, juzgadoTipo, juzgadoCiudad], references: [id, tipo, ciudad])
}

model RelevantDates {
  date   DateTime
  text   String
  id     String   @id
  notaId String?
  Nota   Nota?    @relation(fields: [notaId], references: [id])
}

enum Category {
  Terminados
  LiosJuridicos
  Bancolombia
  Reintegra
  Insolvencia
  SinEspecificar
  todos
  SinTercero
}

enum Departamento {
  BOGOTA
  CUNDINAMARCA
  META
  ANTIOQUIA
  ATLANTICO
}

enum TipoProceso {
  HIPOTECARIO
  PRENDARIO
  SINGULAR
  ACUMULADO
}
